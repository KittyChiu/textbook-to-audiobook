# Textbook-to-Audiobook configuration template.
# Copy this file to `.env` and customize values for your environment.

# -----------------------------
# Stage 1: markdown -> qmd
# -----------------------------
# Directory containing source Markdown chapter files.
MARKDOWN_TO_QMD_INPUT_DIR=markdown
# Directory where generated QMD files are written.
MARKDOWN_TO_QMD_OUTPUT_DIR=qmd

# -----------------------------
# Stage 2: qmd -> ssml
# -----------------------------
# Directory containing QMD input files.
QMD_TO_SSML_INPUT_DIR=qmd
# Directory where generated SSML files are written.
QMD_TO_SSML_OUTPUT_DIR=ssml
# Extra QMD files outside QMD_TO_SSML_INPUT_DIR (comma-separated).
QMD_TO_SSML_EXTRA_TEXT_FILES=

# -----------------------------
# Shared speech settings
# -----------------------------
# Language tag used in generated SSML and TTS fallbacks.
SHARED_SSML_LANG=en-AU
# Azure Neural voice used in generated SSML and TTS fallbacks 
# (https://learn.microsoft.com/en-au/azure/ai-services/speech-service/language-support?tabs=tts).
SHARED_VOICE_NAME=en-AU-WilliamNeural

# -----------------------------
# Stage 3: ssml -> mp3
# -----------------------------
# Directory containing SSML input files.
SSML_TO_MP3_INPUT_DIR=ssml
# Directory where generated MP3 files are written.
SSML_TO_MP3_OUTPUT_DIR=mp3
# Album name for written ID3 metadata.
SSML_TO_MP3_ALBUM=Agentic SDLC Handbook
# Artist name for written ID3 metadata.
SSML_TO_MP3_ARTIST=Daniel Meppiel
# HTTP User-Agent header sent to Azure TTS API.
SSML_TO_MP3_USER_AGENT=browser
# Max SSML UTF-8 bytes per TTS request chunk.
SSML_TO_MP3_MAX_CHUNK_CHARS=5000
# Acronym replacements in generated track titles (JSON object).
SSML_TO_MP3_TITLE_ACRONYMS={"Sdlc":"SDLC","Ai":"AI","Apm":"APM","Prose":"PROSE"}

# -----------------------------
# Azure credentials (required for non-dry runs)
# -----------------------------
# Azure Speech subscription key.
AZURE_TTS_KEY=your-subscription-key
# Azure region for your Speech resource.
AZURE_TTS_REGION=australiaeast
